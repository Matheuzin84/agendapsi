rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: patients
    // Fields:
    //   - name: string (required)
    //   - phone: string (optional)
    //   - email: string (optional)
    //   - notes: string (optional)
    //   - defaultPrice: number (optional)
    //   - psychologistId: string (required, immutable)
    //   - createdAt: timestamp (required, immutable)
    //
    // Collection: sessions
    // Fields:
    //   - patientId: string (required)
    //   - patientName: string (required)
    //   - date: string (required)
    //   - time: string (required)
    //   - location: string (optional)
    //   - locationUri: string (optional)
    //   - meetingLink: string (optional)
    //   - type: string (required, enum: ['online', 'physical'])
    //   - observation: string (optional)
    //   - price: number (optional)
    //   - status: string (required, enum: ['pending', 'confirmed', 'cancelled', 'completed'])
    //   - psychologistId: string (required, immutable)
    //
    // Collection: medicalRecords
    // Fields:
    //   - patientId: string (required)
    //   - sessionId: string (required)
    //   - rawNotes: string (required)
    //   - summary: string (required)
    //   - evolution: string (required)
    //   - psychologistId: string (required, immutable)
    //   - createdAt: timestamp (required, immutable)
    //
    // Collection: messages
    // Fields:
    //   - text: string (required)
    //   - senderId: string (required)
    //   - patientId: string (required)
    //   - psychologistId: string (required, immutable)
    //   - createdAt: timestamp (required, immutable)
    //
    // ===============================================================

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function getUserProfile() {
      return get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data;
    }

    function isPsychologist() {
      return isAuthenticated() && getUserProfile().role == "psychologist";
    }

    function isPatient() {
      return isAuthenticated() && getUserProfile().role == "patient";
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.psychologistId;
    }

    function isNewDocOwner() {
      return isAuthenticated() && request.auth.uid == request.resource.data.psychologistId;
    }

    function isPatientUser() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "mateusdomingos28@hotmail.com" && request.auth.token.email_verified == true);
    }

    // Domain Validators
    function isValidPatient(data) {
      return data.name is string && data.name.size() > 0 &&
             data.psychologistId is string;
    }

    function isValidSession(data) {
      return data.patientId is string &&
             data.date is string &&
             data.time is string &&
             data.psychologistId is string;
    }

    function isValidUserProfile(data) {
      return data.uid == request.auth.uid &&
             data.role in ['psychologist', 'patient'];
    }

    function isValidMedicalRecord(data) {
      return data.patientId is string &&
             data.sessionId is string &&
             data.psychologistId is string;
    }

    function isValidMessage(data) {
      return data.text is string && 
             data.patientId is string &&
             data.psychologistId is string;
    }

    // User Profiles
    match /userProfiles/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isOwner(userId) && isValidUserProfile(request.resource.data);
      allow update: if isAuthenticated() && isOwner(userId) && isValidUserProfile(request.resource.data);
    }

    // Patients
    match /patients/{patientId} {
      allow read: if isAuthenticated() && (isDocOwner() || isPatientUser() || isAdmin());
      allow create: if isAuthenticated() && isValidPatient(request.resource.data);
      allow update: if isAuthenticated() && (isDocOwner() || isPatientUser()) && isValidPatient(request.resource.data);
      allow delete: if isAuthenticated() && (isDocOwner() || isAdmin());
    }

    // Sessions
    match /sessions/{sessionId} {
      allow read: if isAuthenticated() && (
        isDocOwner() || 
        isAdmin() ||
        (resource.data.patientId == request.auth.uid) || // If patientId is actually userId
        (exists(/databases/$(database)/documents/patients/$(resource.data.patientId)) && 
         get(/databases/$(database)/documents/patients/$(resource.data.patientId)).data.userId == request.auth.uid)
      );
      allow create: if isAuthenticated() && isValidSession(request.resource.data);
      allow update: if isAuthenticated() && (isDocOwner() || (resource.data.patientId != null && get(/databases/$(database)/documents/patients/$(resource.data.patientId)).data.userId == request.auth.uid)) && isValidSession(request.resource.data);
      allow delete: if isAuthenticated() && (isDocOwner() || isAdmin());
    }

    // Medical Records
    match /medicalRecords/{recordId} {
      allow read: if isAuthenticated() && (isDocOwner() || isAdmin());
      allow create: if isAuthenticated() && isPsychologist();
      allow update: if isAuthenticated() && isPsychologist() && isDocOwner();
      allow delete: if isAuthenticated() && (isDocOwner() || isAdmin());
    }

    // Messages
    match /messages/{messageId} {
      allow read: if isAuthenticated() && (isDocOwner() || (isPatient() && resource.data.patientId == get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data.patientId) || isAdmin());
      allow create: if isAuthenticated();
      allow delete: if isAuthenticated() && (isDocOwner() || isAdmin());
    }

  }
}
